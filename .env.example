# Copy to .env.local for local dev (gitignored via *.local). Both are build-time (VITE_*) and
# therefore PUBLIC — never put secrets here.

# Clerk publishable key. When set, the app loads the routed, account-aware build (accounts,
# cloud boards, sharing, multiplayer). When unset, it falls back to the local-only Phase-1 board.
#   dev:  pk_test_...   prod: pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=

# Worker host for REST + the WebSocket relay (no protocol).
#   local: localhost:8787      prod: api.jotmodel.com
VITE_WORKER_HOST=localhost:8787
