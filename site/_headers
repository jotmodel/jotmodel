/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Long-cache immutable static assets. These are content-stable; if a file's
# bytes change, change its name (or bust via query) before relying on this.
/tokens.css
  Cache-Control: public, max-age=31536000, immutable
/site.css
  Cache-Control: public, max-age=31536000, immutable
/demo.js
  Cache-Control: public, max-age=31536000, immutable
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/og-image.svg
  Cache-Control: public, max-age=604800

# HTML should always be revalidated so deploys go live immediately.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
