{
  "name": "jotmodel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:worker": "wrangler dev",
    "db:local": "wrangler d1 execute jotmodel --local --file worker/db/schema.sql",
    "db:remote": "wrangler d1 execute jotmodel --remote --file worker/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute jotmodel --local --file worker/db/migrations/0001_projects_thumbnails.sql",
    "db:migrate:remote": "wrangler d1 execute jotmodel --remote --file worker/db/migrations/0001_projects_thumbnails.sql",
    "deploy:worker": "wrangler deploy",
    "deploy:app": "npm run build && wrangler pages deploy dist --project-name jotmodel-app --branch main",
    "deploy:site": "wrangler pages deploy site --project-name jotmodel-site --branch main"
  },
  "dependencies": {
    "@clerk/backend": "^3.7.0",
    "@clerk/clerk-react": "^5.61.8",
    "partyserver": "^0.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.2.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
